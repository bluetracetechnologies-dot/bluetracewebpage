# Public site URL (used for canonical links, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://bluetrace.tech

# --- Lead capture (optional) ---
# Where inquiries and paid orders are forwarded (CRM, Zapier, Make, Google Sheet webhook...)
BLUETRACE_LEAD_WEBHOOK_URL=

# --- Razorpay payments ---
# Get these from https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys while testing, rzp_live_... once your account is activated.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Same key id as RAZORPAY_KEY_ID, but exposed to the browser (safe — the secret is not).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# From Dashboard -> Settings -> Webhooks (only if you enable the webhook endpoint).
RAZORPAY_WEBHOOK_SECRET=
